@model ReferralAdminPageModel
@{ ViewData["Title"]="Referral Program"; ViewData["Subtitle"]="Configure first-deposit bonuses and referral commissions"; }
<div class="mini-stat-row"><div class="mini-stat"><div class="mini-stat-label">Registered through links</div><div class="mini-stat-value">@Model.RegisteredReferralCount</div></div><div class="mini-stat"><div class="mini-stat-label">Qualified referrals</div><div class="mini-stat-value">@Model.QualifiedReferralCount</div></div><div class="mini-stat"><div class="mini-stat-label">Welcome bonuses paid</div><div class="mini-stat-value mono">$@Model.TotalWelcomeBonusPaid.ToString("N2")</div></div><div class="mini-stat"><div class="mini-stat-label">Referral commission paid</div><div class="mini-stat-value mono">$@Model.TotalReferralCommissionPaid.ToString("N2")</div></div></div>
<div class="dash-grid referral-settings-grid">
<form asp-action="SaveWelcomeBonus" method="post"><div class="card card-pad"><div class="card-head"><h3>Welcome Bonus Settings</h3></div><p class="referral-note">Applied once to the new user’s profit balance when their first deposit is approved. The calculation uses the first deposit amount.</p><div class="field-group"><label class="field-label">Welcome bonus %</label><input class="field-input" name="WelcomeBonusPercent" type="number" min="0" max="100" step="0.0001" value="@Model.WelcomeBonusPercent.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)"><small>Example: first deposit $100 × 5% = $5 welcome bonus.</small></div><button class="btn btn-gold" type="submit">Save Welcome Bonus</button></div></form>
<form asp-action="SaveReferralCommission" method="post"><div class="card card-pad"><div class="card-head"><h3>Referral Commission Settings</h3></div><p class="referral-note">Credited once to the referrer’s separate Commission Wallet after the referred user’s first deposit is approved.</p><div class="field-group"><label class="field-label">Referral commission %</label><input class="field-input" name="ReferralCommissionPercent" type="number" min="0" max="100" step="0.0001" value="@Model.ReferralCommissionPercent.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)"><small>Example: referred user deposits $100 × 2% = $2 referral commission.</small></div><button class="btn btn-gold" type="submit">Save Referral Commission</button></div></form>
</div>
<div class="card card-pad" style="margin-top:18px;"><div class="card-head"><h3>Referral Trail</h3></div>@if(Model.Referrals.Count==0){<div class="empty-state">No referral registrations yet.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>Registered</th><th>Referrer</th><th>Referred User</th><th>Status</th><th>First Deposit</th><th>Welcome Bonus</th><th>Commission</th><th>Qualified</th></tr></thead><tbody>@foreach(var row in Model.Referrals){<tr><td>@row.RegisteredAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td><td><strong>@row.ReferrerName</strong><br><span class="mono">@row.ReferrerTraceId</span></td><td><strong>@row.ReferredName</strong><br><span class="mono">@row.ReferredTraceId</span></td><td><span class="badge @(row.IsQualified ? "badge-success" : "badge-pending")">@(row.IsQualified?"Qualified":"Waiting for first deposit")</span></td><td class="mono">$@row.FirstDepositAmount.ToString("N2")</td><td class="mono" style="color:var(--green);">$@row.WelcomeBonusAmount.ToString("N2")</td><td class="mono" style="color:var(--green);">$@row.ReferralCommissionAmount.ToString("N2")</td><td>@(row.QualifiedAtUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "—")</td></tr>}</tbody></table></div>}</div>
