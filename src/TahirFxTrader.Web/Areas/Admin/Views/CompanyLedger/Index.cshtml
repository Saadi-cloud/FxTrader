@model CompanyLedgerPageModel
@{ ViewData["Title"] = "Company Ledger"; ViewData["Subtitle"] = "Company wallet trail for deposits, withdrawal settlements, and fees"; }
<div class="mini-stat-row"><div class="mini-stat"><div class="mini-stat-label">Company Wallet Balance</div><div class="mini-stat-value mono">$@Model.CurrentBalance.ToString("N2")</div></div><div class="mini-stat"><div class="mini-stat-label">Total Credits</div><div class="mini-stat-value mono" style="color:var(--green)">$@Model.Entries.Sum(x=>x.Credit).ToString("N2")</div></div><div class="mini-stat"><div class="mini-stat-label">Total Debits</div><div class="mini-stat-value mono" style="color:var(--red)">$@Model.Entries.Sum(x=>x.Debit).ToString("N2")</div></div></div>
<div class="card card-pad"><div class="card-head"><h3>Company Trail (Ledger)</h3></div>@if(Model.Entries.Count==0){<div class="empty-state">No company ledger entries found.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>Date</th><th>Reference</th><th>Description</th><th>Credit</th><th>Debit</th><th>Running Balance</th></tr></thead><tbody>@foreach(var row in Model.Entries){<tr><td>@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td><td class="mono">@row.ReferenceNo</td><td>@row.Description</td><td class="mono" style="color:var(--green);">@(row.Credit>0?"+$"+row.Credit.ToString("N2"):"—")</td><td class="mono" style="color:var(--red);">@(row.Debit>0?"-$"+row.Debit.ToString("N2"):"—")</td><td class="mono">$@row.BalanceAfter.ToString("N2")</td></tr>}</tbody></table></div>}</div>
