@model IReadOnlyList<PaymentMethod>
@{ ViewData["Title"]="Payment Methods"; ViewData["Subtitle"]="Manage account numbers, wallet addresses, fees, limits, and availability"; }
<div class="card card-pad"><div class="card-head"><h3>Configured Methods</h3><a asp-action="Create" class="btn btn-gold btn-sm">Add Method</a></div>@if(Model.Count==0){<div class="empty-state">No payment methods configured.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>Name</th><th>Type</th><th>Deposit</th><th>Withdrawal</th><th>Deposit Limits</th><th>Withdrawal Limits</th><th>Fees D/W</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var row in Model){<tr><td><strong>@row.Name</strong><br><small class="mono" style="color:var(--text-muted)">@row.Code</small></td><td>@row.MethodType</td><td>@(row.SupportsDeposit?"Yes":"No")</td><td>@(row.SupportsWithdrawal?"Yes":"No")</td><td class="mono">$@row.MinDeposit.ToString("N2") – @(row.MaxDeposit.HasValue?"$"+row.MaxDeposit.Value.ToString("N2"):"No max")</td><td class="mono">$@row.MinWithdrawal.ToString("N2") – @(row.MaxWithdrawal.HasValue?"$"+row.MaxWithdrawal.Value.ToString("N2"):"No max")</td><td>@row.DepositFeePercent.ToString("0.##")% / @row.WithdrawalFeePercent.ToString("0.##")%</td><td><span class="badge @(row.IsActive?"badge-success":"badge-danger")">@(row.IsActive?"Active":"Inactive")</span></td><td><div class="admin-actions"><a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-outline btn-sm">Edit</a><form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Disable this payment method?');"><input type="hidden" name="id" value="@row.Id"><button class="btn btn-ghost btn-sm" type="submit">Delete</button></form></div></td></tr>}</tbody></table></div>}</div>
