@model PaymentMethod
@{ ViewData["Title"] = Model.Id == 0 ? "Add Payment Method" : "Edit Payment Method"; ViewData["Subtitle"]="Configure both user instructions and transaction rules"; }
<form asp-action="Save" method="post" enctype="multipart/form-data"><input asp-for="Id" type="hidden"><input asp-for="QrImagePath" type="hidden"><div asp-validation-summary="ModelOnly"></div>
<div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Method Identity</h3></div><div class="form-grid-2"><div class="field-group"><label class="field-label" asp-for="Name"></label><input class="field-input" asp-for="Name" required></div><div class="field-group"><label class="field-label" asp-for="Code"></label><input class="field-input mono" asp-for="Code" required></div></div><div class="form-grid-2"><div class="field-group"><label class="field-label" asp-for="MethodType">Type</label><select class="field-input" asp-for="MethodType" asp-items="Html.GetEnumSelectList<PaymentMethodType>()"></select></div><div class="field-group"><label class="field-label" asp-for="DisplayOrder">Display order</label><input class="field-input" asp-for="DisplayOrder"></div></div><div class="switch-row"><label class="checkbox-card"><input asp-for="SupportsDeposit"> Supports deposit</label><label class="checkbox-card"><input asp-for="SupportsWithdrawal"> Supports withdrawal</label><label class="checkbox-card"><input asp-for="IsActive"> Active</label></div></div>
<div class="card card-pad"><div class="card-head"><h3>Payment Destination</h3></div><div class="field-group"><label class="field-label" asp-for="AccountTitle">Account title</label><input class="field-input" asp-for="AccountTitle"></div><div class="field-group"><label class="field-label" asp-for="AccountNumber">Account number</label><input class="field-input mono" asp-for="AccountNumber"></div><div class="field-group"><label class="field-label" asp-for="BankName">Bank name</label><input class="field-input" asp-for="BankName"></div><div class="field-group"><label class="field-label" asp-for="WalletAddress">Crypto wallet address</label><input class="field-input mono" asp-for="WalletAddress"></div><div class="field-group"><label class="field-label" asp-for="Network">Network</label><input class="field-input" asp-for="Network" placeholder="e.g. USDT TRC20"></div></div></div>
<div class="dash-grid" style="margin-top:18px;"><div class="card card-pad"><div class="card-head"><h3>Deposit Rules</h3></div><div class="field-group"><label class="field-label" asp-for="MinDeposit">Minimum deposit</label><input class="field-input" asp-for="MinDeposit"></div><div class="field-group"><label class="field-label" asp-for="MaxDeposit">Maximum deposit</label><input class="field-input" asp-for="MaxDeposit" placeholder="Leave blank for no fixed maximum"></div><div class="field-group"><label class="field-label" asp-for="DepositFeePercent">Deposit fee %</label><input class="field-input" asp-for="DepositFeePercent"></div></div><div class="card card-pad"><div class="card-head"><h3>Withdrawal Rules</h3></div><div class="field-group"><label class="field-label" asp-for="MinWithdrawal">Minimum withdrawal</label><input class="field-input" asp-for="MinWithdrawal"></div><div class="field-group"><label class="field-label" asp-for="MaxWithdrawal">Maximum withdrawal</label><input class="field-input" asp-for="MaxWithdrawal" placeholder="Leave blank for no fixed maximum"></div><div class="field-group"><label class="field-label" asp-for="WithdrawalFeePercent">Legacy method fee %</label><input class="field-input" asp-for="WithdrawalFeePercent"><small style="color:var(--text-muted)">Not applied by the wallet-source withdrawal flow. Investment fee is controlled in System Settings.</small></div></div></div>
<div class="card card-pad" style="margin-top:18px;"><div class="form-grid-2"><div class="field-group"><label class="field-label" asp-for="Instructions">User instructions</label><textarea class="field-input textarea" asp-for="Instructions"></textarea></div><div class="field-group"><label class="field-label">QR image</label><div class="upload-box"><input type="file" name="qrImage" accept="image/png,image/jpeg,image/webp"><div class="upload-box-title">Upload payment QR image</div><div class="upload-box-sub">Optional, up to 3MB</div></div>@if(!string.IsNullOrWhiteSpace(Model.QrImagePath)){<p style="margin-top:8px;"><a href="@Model.QrImagePath" target="_blank">View current QR image</a></p>}</div></div></div>
<div class="admin-actions" style="margin-top:18px;"><button class="btn btn-gold" type="submit">Save Payment Method</button><a asp-action="Index" class="btn btn-outline">Cancel</a></div></form>
