@model AdminDashboardData
@{ ViewData["Title"]="Admin Dashboard"; ViewData["Subtitle"]="System-wide users, balances, deposits, and withdrawals"; }
<div class="balance-hero"><div class="balance-hero-top"><div><div class="balance-label">Total User Wallet Liability</div><div class="balance-amount mono">$@Model.TotalWalletBalance.ToString("N2")<sup>USD</sup></div><div class="balance-change">Available plus held user balances</div></div><div class="balance-actions"><a asp-controller="Deposits" asp-action="Index" class="btn btn-gold">Review Deposits</a><a asp-controller="Withdrawals" asp-action="Index" class="btn btn-outline">Review Withdrawals</a></div></div><div class="balance-sub-row"><div class="balance-sub-item">Users<strong>@Model.TotalUsers</strong></div><div class="balance-sub-item">Active users<strong>@Model.ActiveUsers</strong></div><div class="balance-sub-item">Deposits approved today<strong class="mono" style="color:var(--green);">$@Model.ApprovedDepositsToday.ToString("N2")</strong></div><div class="balance-sub-item">Withdrawals completed today<strong class="mono">$@Model.CompletedWithdrawalsToday.ToString("N2")</strong></div></div></div>
<div class="stat-grid"><div class="stat-card"><div class="stat-label">Total Users</div><div class="stat-value">@Model.TotalUsers</div><div class="stat-delta">@Model.ActiveUsers active</div></div><div class="stat-card"><div class="stat-label">Pending Deposits</div><div class="stat-value">@Model.PendingDeposits</div><div class="stat-delta" style="color:var(--gold);">Requires verification</div></div><div class="stat-card"><div class="stat-label">Pending Withdrawals</div><div class="stat-value">@Model.PendingWithdrawals</div><div class="stat-delta" style="color:var(--gold);">Requires manual payment</div></div><div class="stat-card"><div class="stat-label">System Status</div><div class="stat-value" style="color:var(--green);font-size:22px;">Operational</div><div class="stat-delta">Database controls active</div></div></div>
<div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Transaction Operations</h3></div><div class="plan-row"><div><div class="plan-name">Deposit verification queue</div><div class="plan-meta">Inspect proof, reference, sender, and method</div></div><a asp-controller="Deposits" asp-action="Index" class="btn btn-outline btn-sm">Open</a></div><div class="plan-row"><div><div class="plan-name">Withdrawal payment queue</div><div class="plan-meta">Reserve, process, complete, or reject requests</div></div><a asp-controller="Withdrawals" asp-action="Index" class="btn btn-outline btn-sm">Open</a></div></div><div class="card card-pad"><div class="card-head"><h3>Configuration</h3></div><div class="plan-row"><div><div class="plan-name">Payment methods</div><div class="plan-meta">JazzCash, EasyPaisa, bank, crypto, and custom options</div></div><a asp-controller="PaymentMethods" asp-action="Index" class="btn btn-outline btn-sm">Manage</a></div><div class="plan-row"><div><div class="plan-name">Withdrawal rules</div><div class="plan-meta">Default minimum, maximum, and fee percentage</div></div><a asp-controller="Settings" asp-action="Index" class="btn btn-outline btn-sm">Manage</a></div></div></div>
