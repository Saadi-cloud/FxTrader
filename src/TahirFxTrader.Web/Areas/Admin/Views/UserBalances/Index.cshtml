@model IReadOnlyList<AdminUserBalanceItem>
@{ ViewData["Title"]="User Balances"; ViewData["Subtitle"]="Manage investment, compound profit, and referral commission wallets separately"; }
<div class="card card-pad"><div class="card-head"><div><h3>User Wallets</h3><p style="color:var(--text-muted);margin:6px 0 0;font-size:13px;">Profit is calculated on Investment + existing Profit. Commission is excluded from compounding. Withdrawals consume Profit, then Commission, then Investment.</p></div><a asp-action="ApplyProfitToAll" class="btn btn-gold">Apply Profit % to All Users</a></div>
@if(Model.Count==0){<div class="empty-state">No user balances found.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>User ID</th><th>User</th><th>Investment</th><th>Profit</th><th>Commission</th><th>Compound Base</th><th>Available</th><th>On Hold</th><th>Total Wallet</th><th></th></tr></thead><tbody>@foreach(var row in Model){<tr><td class="mono"><strong>@row.UserTraceId</strong></td><td><strong>@row.FullName</strong><div style="color:var(--text-muted);font-size:12px;">@row.Email</div></td><td class="mono">$@row.InvestmentBalance.ToString("N2")</td><td class="mono" style="color:var(--green);">$@row.ProfitBalance.ToString("N2")</td><td class="mono" style="color:var(--gold);">$@row.CommissionBalance.ToString("N2")</td><td class="mono">$@row.CompoundProfitBase.ToString("N2")</td><td class="mono">$@row.AvailableBalance.ToString("N2")</td><td class="mono">$@row.HeldBalance.ToString("N2")</td><td class="mono">$@row.TotalWalletValue.ToString("N2")</td><td><a asp-action="AddProfit" asp-route-id="@row.UserId" class="btn btn-gold btn-sm">Add Profit %</a></td></tr>}</tbody></table></div>}</div>
