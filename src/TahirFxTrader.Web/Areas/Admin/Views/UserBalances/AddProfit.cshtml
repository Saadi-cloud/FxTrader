@model ApplyProfitRequest
@{ ViewData["Title"]="Add User Profit"; ViewData["Subtitle"]="Apply compound profit to investment plus existing profit"; }
<form method="post"><input asp-for="UserId" type="hidden"><div asp-validation-summary="ModelOnly"></div><div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>@Model.FullName</h3></div><div class="detail-row"><span>Email</span><strong>@Model.Email<br><span class="mono" style="color:var(--gold)">@Model.UserTraceId</span></strong></div><div class="detail-row"><span>Investment Wallet</span><strong class="mono">$@Model.InvestmentBalance.ToString("N2")</strong></div><div class="detail-row"><span>Profit Wallet</span><strong class="mono" style="color:var(--green);">$@Model.ProfitBalance.ToString("N2")</strong></div><div class="detail-row"><span>Commission Wallet</span><strong class="mono" style="color:var(--gold);">$@Model.CommissionBalance.ToString("N2")</strong></div><div class="detail-row"><span>Compound Profit Base</span><strong class="mono">$@Model.CompoundProfitBase.ToString("N2")</strong></div><div class="alert-box alert-info"><span>Profit compounds on Investment + existing Profit. Commission is kept separate and is never included. Example: investment $100, first 2% profit = $2; next 2% is calculated on $102 and credits $2.04 to Profit Wallet.</span></div></div>
<div class="card card-pad"><div class="card-head"><h3>Profit Percentage</h3></div><div class="field-group"><label class="field-label" asp-for="ProfitPercentage">Profit percentage (%)</label><input class="field-input" asp-for="ProfitPercentage" type="number" min="0.0001" max="100" step="0.0001" id="profitPercentage"><span asp-validation-for="ProfitPercentage"></span></div><div class="preset-row"><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="1">1%</button><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="2">2%</button><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="5">5%</button><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="10">10%</button></div><div class="field-group" style="margin-top:16px;"><label class="field-label">Calculated profit</label><div class="field-input mono" id="profitPreview">$0.00</div></div><div class="field-group"><label class="field-label" asp-for="Note"></label><textarea class="field-input" asp-for="Note" rows="3" placeholder="Optional admin note"></textarea><span asp-validation-for="Note"></span></div><div class="admin-actions"><button class="btn btn-gold" type="submit">Credit Compound Profit</button><a asp-action="Index" class="btn btn-outline">Cancel</a></div></div></div></form>
@section Scripts {<script>(()=>{const input=document.getElementById('profitPercentage');const preview=document.getElementById('profitPreview');const baseAmount=@Model.CompoundProfitBase.ToString(System.Globalization.CultureInfo.InvariantCulture);function update(){const pct=parseFloat(input.value||'0');preview.textContent='$'+(baseAmount*pct/100).toFixed(2);}document.querySelectorAll('.profit-preset').forEach(b=>b.addEventListener('click',()=>{input.value=b.dataset.value;update();}));input.addEventListener('input',update);update();})();</script>}
