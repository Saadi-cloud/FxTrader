@model ApplyProfitToAllRequest
@{ ViewData["Title"]="Apply Profit to All Users"; ViewData["Subtitle"]="Credit the same compound profit percentage to every eligible active user"; }
<form method="post"><div asp-validation-summary="ModelOnly"></div><div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Eligible Wallets</h3></div><div class="detail-row"><span>Eligible users</span><strong class="mono">@Model.EligibleUserCount</strong></div><div class="detail-row"><span>Total compounding base</span><strong class="mono">$@Model.TotalCompoundingBase.ToString("N2")</strong></div><div class="detail-row"><span>Estimated total profit</span><strong class="mono" id="totalProfitPreview" style="color:var(--green);">$@Model.EstimatedTotalProfit.ToString("N2")</strong></div><div class="alert-box alert-info"><span>Each user's base is Investment Wallet + Profit Wallet. Commission Wallet is excluded. This means profit compounds each time it is applied.</span></div><div class="alert-box alert-warning"><span>This action creates one batch reference and a separate PFT reference and wallet-ledger entry for every credited user. The entire batch is committed together.</span></div></div><div class="card card-pad"><div class="card-head"><h3>Bulk Profit Percentage</h3></div><div class="field-group"><label class="field-label" asp-for="ProfitPercentage">Profit percentage (%)</label><input class="field-input" asp-for="ProfitPercentage" type="number" min="0.0001" max="100" step="0.0001" id="profitPercentage"><span asp-validation-for="ProfitPercentage"></span></div><div class="preset-row"><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="1">1%</button><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="2">2%</button><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="5">5%</button><button type="button" class="btn btn-outline btn-sm profit-preset" data-value="10">10%</button></div><div class="field-group" style="margin-top:16px;"><label class="field-label" asp-for="Note">Batch note</label><textarea class="field-input" asp-for="Note" rows="3" placeholder="Example: Monthly compound profit"></textarea><span asp-validation-for="Note"></span></div><label class="checkbox-card" style="margin-top:14px;"><input asp-for="Confirmed">I confirm this percentage should be credited to every eligible user.</label><span asp-validation-for="Confirmed"></span>@if (Model.EligibleUserCount == 0){<div class="alert-box alert-warning" style="margin-top:14px;"><span>No eligible users currently have an investment plus profit balance.</span></div>}<div class="admin-actions" style="margin-top:18px;"><button class="btn btn-gold" type="submit" disabled="@(Model.EligibleUserCount == 0)">Apply to All Eligible Users</button><a asp-action="Index" class="btn btn-outline">Cancel</a></div></div></div></form>
@section Scripts {<script>(()=>{const input=document.getElementById('profitPercentage');const preview=document.getElementById('totalProfitPreview');const baseAmount=@Model.TotalCompoundingBase.ToString(System.Globalization.CultureInfo.InvariantCulture);function update(){const pct=parseFloat(input.value||'0');preview.textContent='$'+(baseAmount*pct/100).toFixed(2);}document.querySelectorAll('.profit-preset').forEach(button=>button.addEventListener('click',()=>{input.value=button.dataset.value;update();}));input.addEventListener('input',update);update();})();</script>}
