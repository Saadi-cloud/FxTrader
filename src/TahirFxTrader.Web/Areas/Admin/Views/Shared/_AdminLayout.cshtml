@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Active(string name) => controller.Equals(name, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    var title = ViewData["Title"]?.ToString() ?? "Admin Dashboard";
    var sub = ViewData["Subtitle"]?.ToString() ?? "Manage users, methods and transactions";
}
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>@title Admin</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link rel="stylesheet" href="~/css/style.css" asp-append-version="true"></head><body>
<div class="app-shell"><div class="sidebar-overlay"></div><aside class="sidebar"><div class="brand"><a href="/"><img class="brand-logo" src="/images/brand/logo.png" alt="OLX Trade"></a></div><div class="brand"><div class="brand-mark"></div><div class="brand-name">OLX <span>Admin</span></div></div><nav class="sidebar-nav">
<div class="nav-section-label">Administration</div>
<a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link @Active("Dashboard")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Overview</a>
<a asp-area="Admin" asp-controller="Users" asp-action="Index" class="nav-link @Active("Users")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M2 21c0-4 3-7 7-7s7 3 7 7M16 3c3 0 5 2 5 5s-2 5-5 5"/></svg>Users</a>
<a asp-area="Admin" asp-controller="UserBalances" asp-action="Index" class="nav-link @Active("UserBalances")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M8 12h8M12 8v8"/></svg>User Balances</a>
<a asp-area="Admin" asp-controller="Referrals" asp-action="Index" class="nav-link @Active("Referrals")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="8" r="3"/><circle cx="17" cy="7" r="2.5"/><path d="M2 21c0-4 2.7-7 6-7s6 3 6 7M14 14c3 0 5 2.5 5 6"/></svg>Referrals</a>
<a asp-area="Admin" asp-controller="PaymentMethods" asp-action="Index" class="nav-link @Active("PaymentMethods")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="15" rx="2"/><path d="M2 10h20"/></svg>Payment Methods</a>
<a asp-area="Admin" asp-controller="Deposits" asp-action="Index" class="nav-link @Active("Deposits")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"/></svg>Deposits</a>
<a asp-area="Admin" asp-controller="Withdrawals" asp-action="Index" class="nav-link @Active("Withdrawals")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>Withdrawals</a>
<a asp-area="Admin" asp-controller="CompanyLedger" asp-action="Index" class="nav-link @Active("CompanyLedger")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18M6 12h12M8 17h8"/></svg>Company Ledger</a>
<a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="nav-link @Active("Settings")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06-2.83 2.83-.06-.06a1.65 1.65 0 0 0-1.82-.33A1.65 1.65 0 0 0 14 21h-4a1.65 1.65 0 0 0-1.08-1.55 1.65 1.65 0 0 0-1.82.33l-.06.06-2.83-2.83.06-.06A1.65 1.65 0 0 0 4.6 15 1.65 1.65 0 0 0 3 14v-4a1.65 1.65 0 0 0 1.6-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06L7.04 4.3l.06.06A1.65 1.65 0 0 0 8.92 4 1.65 1.65 0 0 0 10 2.5h4A1.65 1.65 0 0 0 15.08 4a1.65 1.65 0 0 0 1.82.33l.06-.06 2.83 2.83-.06.06A1.65 1.65 0 0 0 19.4 9 1.65 1.65 0 0 0 21 10v4a1.65 1.65 0 0 0-1.6 1z"/></svg>Settings</a>
<div class="nav-section-label">User Area</div><a asp-area="" asp-controller="Dashboard" asp-action="Index" class="nav-link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>Open User Dashboard</a>
</nav><div class="sidebar-footer"><form asp-area="" asp-controller="Auth" asp-action="Logout" method="post"><button type="submit" class="logout-link" style="border:0;background:none;width:100%;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg>Log out</button></form></div></aside>
<div class="main"><header class="topbar"><div class="topbar-left"><button class="menu-toggle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button><div><div class="page-title">@title</div><div class="page-sub">@sub</div></div></div><div class="user-chip"><div class="user-avatar">@User.Initials()</div><div><div class="user-chip-name">@User.Identity?.Name</div><div class="user-chip-tier">Administrator · <span class="mono">@User.FindFirst("user_trace_id")?.Value</span></div></div></div></header><main class="content"><partial name="~/Views/Shared/_Flash.cshtml" />@RenderBody()</main><footer class="app-footer"><span>OLX Trade Administration</span><span>Secure operations console</span></footer></div></div>
<script src="~/js/app.js" asp-append-version="true"></script>@await RenderSectionAsync("Scripts", required:false)</body></html>
