@model DepositTransaction
@{ ViewData["Title"]="Deposit Details"; ViewData["Subtitle"]=$"Review request {Model.ReferenceNo}"; }
<div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Request Information</h3><span class="badge @(Model.Status==TransactionStatus.Approved?"badge-success":Model.Status==TransactionStatus.Rejected?"badge-danger":"badge-pending")">@Model.Status</span></div><div class="detail-grid"><div class="detail-item"><span>User</span><strong>@Model.UserName<br><span class="mono" style="color:var(--gold)">@Model.UserTraceId</span><br>@Model.UserEmail</strong></div><div class="detail-item"><span>Reference</span><strong class="mono">@Model.ReferenceNo</strong></div><div class="detail-item"><span>Payment method</span><strong>@Model.PaymentMethodName</strong></div><div class="detail-item"><span>Transaction ID</span><strong class="mono">@Model.TransactionReference</strong></div><div class="detail-item"><span>Sender account</span><strong>@Model.SenderAccount</strong></div><div class="detail-item"><span>Submitted</span><strong>@Model.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</strong></div><div class="detail-item"><span>Gross amount</span><strong class="mono">$@Model.Amount.ToString("N2")</strong></div><div class="detail-item"><span>Wallet credit</span><strong class="mono" style="color:var(--green);">$@Model.NetAmount.ToString("N2")</strong></div></div>@if(!string.IsNullOrWhiteSpace(Model.AdminNote)){<div class="alert-box alert-info"><span><strong>Admin note:</strong> @Model.AdminNote</span></div>}</div><div class="card card-pad"><div class="card-head"><h3>Payment Screenshot</h3></div><a href="@Model.ScreenshotPath" target="_blank"><img class="proof-image" src="@Model.ScreenshotPath" alt="Payment proof"></a></div></div>
@if(Model.Status==TransactionStatus.Pending){<div class="card card-pad" style="margin-top:18px;"><div class="card-head"><h3>Decision</h3></div><form method="post"><input type="hidden" name="Id" value="@Model.Id"><div class="field-group"><label class="field-label">Admin note</label><textarea class="field-input textarea" name="AdminNote" placeholder="Verification note or rejection reason"></textarea></div><div class="admin-actions"><button asp-action="Approve" class="btn btn-gold" type="submit" onclick="return confirm('Approve and credit this user wallet?');">Approve & Credit Wallet</button><button asp-action="Reject" class="btn btn-outline" type="submit" onclick="return confirm('Reject this deposit request?');">Reject Deposit</button></div></form></div>}
<div style="margin-top:18px;"><a asp-action="Index" class="btn btn-ghost">← Back to deposits</a></div>
