@model IReadOnlyList<DepositTransaction>
@{ ViewData["Title"]="Deposit Review"; ViewData["Subtitle"]="Verify payment proof before crediting a user wallet"; string Badge(TransactionStatus s)=>s==TransactionStatus.Approved?"badge-success":s==TransactionStatus.Rejected?"badge-danger":"badge-pending"; }
<div class="mini-stat-row"><div class="mini-stat"><div class="mini-stat-label">Pending Requests</div><div class="mini-stat-value">@Model.Count(x=>x.Status==TransactionStatus.Pending)</div></div><div class="mini-stat"><div class="mini-stat-label">Pending Value</div><div class="mini-stat-value mono">$@Model.Where(x=>x.Status==TransactionStatus.Pending).Sum(x=>x.Amount).ToString("N2")</div></div><div class="mini-stat"><div class="mini-stat-label">Approved Total</div><div class="mini-stat-value mono" style="color:var(--green);">$@Model.Where(x=>x.Status==TransactionStatus.Approved).Sum(x=>x.NetAmount).ToString("N2")</div></div></div>
<div class="card card-pad"><div class="card-head"><h3>All Deposit Requests</h3></div>@if(Model.Count==0){<div class="empty-state">No deposit requests.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>Date</th><th>User</th><th>Reference</th><th>Method</th><th>Transaction ID</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var row in Model){<tr><td>@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td><td><strong>@row.UserName</strong><br><small class="mono" style="color:var(--gold)">@row.UserTraceId</small><br><small style="color:var(--text-muted)">@row.UserEmail</small></td><td class="mono">@row.ReferenceNo</td><td>@row.PaymentMethodName</td><td class="mono">@row.TransactionReference</td><td class="mono">$@row.Amount.ToString("N2")</td><td><span class="badge @Badge(row.Status)">@row.Status</span></td><td><a asp-action="Details" asp-route-id="@row.Id" class="btn btn-outline btn-sm">Review</a></td></tr>}</tbody></table></div>}</div>
