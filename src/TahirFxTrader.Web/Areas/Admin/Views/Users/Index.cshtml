@model IReadOnlyList<AdminUserListItem>
@{ ViewData["Title"]="Users"; ViewData["Subtitle"]="User management, account controls, and balances"; }
<div class="card card-pad"><div class="card-head"><div><h3>All User Accounts</h3><p style="color:var(--text-muted);margin:6px 0 0;font-size:13px;">Search by User ID, name, email, phone, or country.</p></div><a asp-action="Create" class="btn btn-gold">Add User</a></div>
<div class="field-group" style="max-width:520px;"><label class="field-label" for="userTraceSearch">Find user</label><input id="userTraceSearch" class="field-input" placeholder="Example: USR-20260715-000001"></div>
@if(Model.Count==0){<div class="empty-state">No users found.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>User ID</th><th>Name</th><th>Country</th><th>Phone</th><th>Email</th><th>Role</th><th>Status</th><th>Investment</th><th>Profit</th><th>Wallet</th><th>Created</th><th></th></tr></thead><tbody id="userTraceRows">@foreach(var row in Model){<tr data-search="@row.UserTraceId @row.FullName @row.Email @row.PhoneNumber @row.Country"><td class="mono"><strong>@row.UserTraceId</strong></td><td>@row.FullName</td><td>@row.Country</td><td class="mono">@row.PhoneNumber</td><td>@row.Email</td><td>@row.RoleName</td><td><span class="status-badge status-@row.Status.ToString().ToLowerInvariant()">@row.Status</span></td><td class="mono">$@row.InvestmentBalance.ToString("N2")</td><td class="mono" style="color:var(--green);">$@row.ProfitBalance.ToString("N2")</td><td class="mono">$@row.AvailableBalance.ToString("N2")</td><td>@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td><td><a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-sm btn-outline">Manage</a></td></tr>}</tbody></table></div>}</div>
@section Scripts {<script>document.getElementById('userTraceSearch')?.addEventListener('input',function(){const q=this.value.trim().toLowerCase();document.querySelectorAll('#userTraceRows tr').forEach(r=>r.style.display=!q||r.dataset.search.toLowerCase().includes(q)?'':'none');});</script>}
