@model RegisterRequest
@{ ViewData["Title"]="Add User"; ViewData["Subtitle"]="Create an account and send its email verification code"; var countries = new[]{"Pakistan","Saudi Arabia","United Arab Emirates","Qatar","Oman","Bahrain","Kuwait","United Kingdom","United States","Canada","Australia","India","Bangladesh","Malaysia","Singapore","Turkey","Other"}; }
<form method="post"><div asp-validation-summary="ModelOnly"></div><div class="card card-pad" style="max-width:780px;"><div class="card-head"><h3>New User Account</h3></div><div class="field-group"><label class="field-label" asp-for="FullName"></label><input class="field-input" asp-for="FullName"><span asp-validation-for="FullName"></span></div><div class="form-grid-2"><div class="field-group"><label class="field-label" asp-for="Country"></label><select class="field-input" asp-for="Country"><option value="">Select country</option>@foreach(var country in countries){<option value="@country">@country</option>}</select><span asp-validation-for="Country"></span></div><div class="field-group"><label class="field-label" asp-for="PhoneNumber">Phone</label><input class="field-input" asp-for="PhoneNumber"><span asp-validation-for="PhoneNumber"></span></div></div><div class="field-group"><label class="field-label" asp-for="Email"></label><input class="field-input" asp-for="Email"><span asp-validation-for="Email"></span></div><div class="field-group"><label class="field-label" asp-for="ReferralCode">Referral code (optional)</label><input class="field-input mono" asp-for="ReferralCode" placeholder="USR-YYYYMMDD-000001"><span asp-validation-for="ReferralCode"></span></div><div class="form-grid-2"><div class="field-group"><label class="field-label" asp-for="Password"></label><input class="field-input" asp-for="Password"><span asp-validation-for="Password"></span></div><div class="field-group"><label class="field-label" asp-for="ConfirmPassword"></label><input class="field-input" asp-for="ConfirmPassword"><span asp-validation-for="ConfirmPassword"></span></div></div><div class="alert-box alert-info"><span>The user starts in Pending status and must enter the email code before login. You can also manage verification and status from the Edit User page.</span></div><div class="admin-actions"><button class="btn btn-gold" type="submit">Create User</button><a asp-action="Index" class="btn btn-outline">Cancel</a></div></div></form>
