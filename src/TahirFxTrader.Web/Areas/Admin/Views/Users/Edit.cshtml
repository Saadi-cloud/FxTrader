@model AdminUserEditModel
@{ ViewData["Title"]="Manage User"; ViewData["Subtitle"]="Update account status, eligibility, limits, and page permissions"; var all=(string[])ViewBag.AllPermissions; var countries = new[]{"Pakistan","Saudi Arabia","United Arab Emirates","Qatar","Oman","Bahrain","Kuwait","United Kingdom","United States","Canada","Australia","India","Bangladesh","Malaysia","Singapore","Turkey","Other"}; }
<form method="post"><input asp-for="Id" type="hidden"><div asp-validation-summary="ModelOnly"></div><div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Account Details</h3></div><div class="field-group"><label class="field-label">User Trace ID</label><input class="field-input mono" value="@Model.UserTraceId" readonly></div><div class="field-group"><label class="field-label" asp-for="FullName"></label><input class="field-input" asp-for="FullName"><span asp-validation-for="FullName"></span></div><div class="form-grid-2"><div class="field-group"><label class="field-label" asp-for="Country"></label><select class="field-input" asp-for="Country">@foreach(var country in countries){<option value="@country">@country</option>}</select><span asp-validation-for="Country"></span></div><div class="field-group"><label class="field-label" asp-for="PhoneNumber">Phone</label><input class="field-input" asp-for="PhoneNumber"><span asp-validation-for="PhoneNumber"></span></div></div><div class="field-group"><label class="field-label" asp-for="Email"></label><input class="field-input" asp-for="Email"><span asp-validation-for="Email"></span></div><div class="form-grid-2"><div class="field-group"><label class="field-label" asp-for="RoleName">Role</label><select class="field-input" asp-for="RoleName"><option>User</option><option>Admin</option></select></div><div class="field-group"><label class="field-label" asp-for="Status"></label><select class="field-input" asp-for="Status" asp-items="Html.GetEnumSelectList<AccountStatus>()"></select></div></div><div class="switch-row"><label class="checkbox-card"><input asp-for="IsEmailVerified"> Email verified</label><label class="checkbox-card"><input asp-for="CanDeposit"> Can deposit</label><label class="checkbox-card"><input asp-for="CanWithdraw"> Can withdraw</label></div></div>
<div class="card card-pad"><div class="card-head"><h3>Withdrawal Overrides</h3></div><p style="color:var(--text-muted);font-size:13px;">Leave blank to use the global setting.</p><div class="field-group"><label class="field-label" asp-for="WithdrawalMinOverride">Minimum withdrawal</label><input class="field-input" asp-for="WithdrawalMinOverride"><span asp-validation-for="WithdrawalMinOverride"></span></div><div class="field-group"><label class="field-label" asp-for="WithdrawalMaxOverride">Maximum withdrawal</label><input class="field-input" asp-for="WithdrawalMaxOverride"><span asp-validation-for="WithdrawalMaxOverride"></span></div><div class="field-group"><label class="field-label" asp-for="WithdrawalFeePercentOverride">Investment withdrawal fee override %</label><input class="field-input" asp-for="WithdrawalFeePercentOverride"><span asp-validation-for="WithdrawalFeePercentOverride"></span></div></div></div>
<div class="card card-pad" style="margin-top:18px;"><div class="card-head"><h3>Form and Page Access</h3></div><div class="permission-grid">@foreach(var permission in all){<label class="permission-item"><input type="checkbox" name="Permissions" value="@permission" @(Model.Permissions.Contains(permission,StringComparer.OrdinalIgnoreCase) ? "checked" : "")><span>@permission</span></label>}</div></div><div class="admin-actions" style="margin-top:18px;"><button class="btn btn-gold" type="submit">Save User Controls</button><a asp-action="Index" class="btn btn-outline">Cancel</a></div></form>
