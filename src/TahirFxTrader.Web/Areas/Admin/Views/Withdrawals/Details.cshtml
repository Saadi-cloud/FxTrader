@model WithdrawalTransaction
@{ ViewData["Title"]="Withdrawal Details"; ViewData["Subtitle"]=$"Review request {Model.ReferenceNo}"; }
<div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Request Information</h3><span class="badge @(Model.Status==TransactionStatus.Completed?"badge-success":Model.Status==TransactionStatus.Rejected?"badge-danger":"badge-pending")">@Model.Status</span></div><div class="detail-grid"><div class="detail-item"><span>User</span><strong>@Model.UserName<br><span class="mono" style="color:var(--gold)">@Model.UserTraceId</span><br>@Model.UserEmail</strong></div><div class="detail-item"><span>Reference</span><strong class="mono">@Model.ReferenceNo</strong></div><div class="detail-item"><span>Wallet source</span><strong>@(Model.WalletSource=="Investment"?"Investment Wallet":Model.WalletSource=="ProfitCommission"?"Profit + Commission":"Legacy mixed")</strong></div><div class="detail-item"><span>Method</span><strong>@Model.PaymentMethodName</strong></div><div class="detail-item"><span>Destination</span><strong>@Model.DestinationDisplay</strong></div><div class="detail-item"><span>Requested amount</span><strong class="mono">$@Model.Amount.ToString("N2")</strong></div><div class="detail-item"><span>Fee</span><strong class="mono">@Model.FeePercent.ToString("0.##")% · $@Model.FeeAmount.ToString("N2")</strong></div><div class="detail-item"><span>Amount to send</span><strong class="mono" style="color:var(--green);">$@Model.NetAmount.ToString("N2")</strong></div><div class="detail-item"><span>From profit</span><strong class="mono" style="color:var(--green);">$@Model.ProfitAmount.ToString("N2")</strong></div><div class="detail-item"><span>From commission</span><strong class="mono" style="color:var(--gold);">$@Model.CommissionAmount.ToString("N2")</strong></div><div class="detail-item"><span>From investment</span><strong class="mono">$@Model.InvestmentAmount.ToString("N2")</strong></div><div class="detail-item"><span>Submitted</span><strong>@Model.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</strong></div></div>@if(!string.IsNullOrWhiteSpace(Model.AdminPaymentReference)){<div class="alert-box alert-info"><span><strong>Payment reference:</strong> @Model.AdminPaymentReference</span></div>}@if(!string.IsNullOrWhiteSpace(Model.AdminNote)){<div class="alert-box alert-info"><span><strong>Admin note:</strong> @Model.AdminNote</span></div>}</div><div class="card card-pad"><div class="card-head"><h3>Raw Destination Details</h3></div><pre class="mono" style="white-space:pre-wrap;color:var(--text);background:var(--bg-soft);padding:16px;border-radius:8px;border:1px solid var(--border);">@Model.DestinationJson</pre><div class="alert-box alert-warning"><span>Confirm all destination details before manually sending funds. Completion cannot be reversed inside this application.</span></div></div></div>
@if(Model.Status==TransactionStatus.Pending || Model.Status==TransactionStatus.Processing){<div class="card card-pad" style="margin-top:18px;"><div class="card-head"><h3>Process Request</h3></div><form method="post"><input type="hidden" name="Id" value="@Model.Id"><div class="form-grid-2"><div class="field-group"><label class="field-label">Payment reference</label><input class="field-input" name="PaymentReference" placeholder="Required when completing"></div><div class="field-group"><label class="field-label">Admin note</label><input class="field-input" name="AdminNote" placeholder="Optional processing note or rejection reason"></div></div><div class="admin-actions">@if(Model.Status==TransactionStatus.Pending){<button asp-action="Process" class="btn btn-outline" type="submit">Mark Processing</button>}<button asp-action="Complete" class="btn btn-gold" type="submit" onclick="return confirm('Confirm that payment has been sent and complete this withdrawal?');">Complete Withdrawal</button><button asp-action="Reject" class="btn btn-outline" type="submit" onclick="return confirm('Reject and return reserved funds to the user?');">Reject & Release Funds</button></div></form></div>}
<div style="margin-top:18px;"><a asp-action="Index" class="btn btn-ghost">← Back to withdrawals</a></div>
