@model IReadOnlyList<WithdrawalTransaction>
@{ ViewData["Title"]="Withdrawal Review"; ViewData["Subtitle"]="Manually send payment, then complete or reject the reserved request"; string Badge(TransactionStatus s)=>s==TransactionStatus.Completed?"badge-success":s==TransactionStatus.Rejected?"badge-danger":"badge-pending"; }
<div class="mini-stat-row"><div class="mini-stat"><div class="mini-stat-label">Pending / Processing</div><div class="mini-stat-value">@Model.Count(x=>x.Status==TransactionStatus.Pending||x.Status==TransactionStatus.Processing)</div></div><div class="mini-stat"><div class="mini-stat-label">Reserved Value</div><div class="mini-stat-value mono">$@Model.Where(x=>x.Status==TransactionStatus.Pending||x.Status==TransactionStatus.Processing).Sum(x=>x.Amount).ToString("N2")</div></div><div class="mini-stat"><div class="mini-stat-label">Completed Total</div><div class="mini-stat-value mono" style="color:var(--green);">$@Model.Where(x=>x.Status==TransactionStatus.Completed).Sum(x=>x.Amount).ToString("N2")</div></div></div>
<div class="card card-pad"><div class="card-head"><h3>All Withdrawal Requests</h3></div>@if(Model.Count==0){<div class="empty-state">No withdrawal requests.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>Date</th><th>User</th><th>Reference</th><th>Wallet</th><th>Method</th><th>Destination</th><th>Amount</th><th>Receive</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var row in Model){<tr><td>@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td><td><strong>@row.UserName</strong><br><small class="mono" style="color:var(--gold)">@row.UserTraceId</small><br><small style="color:var(--text-muted)">@row.UserEmail</small></td><td class="mono">@row.ReferenceNo</td><td>@(row.WalletSource=="Investment"?"Investment":"Profit + Commission")</td><td>@row.PaymentMethodName</td><td>@row.DestinationDisplay</td><td class="mono">$@row.Amount.ToString("N2")</td><td class="mono">$@row.NetAmount.ToString("N2")</td><td><span class="badge @Badge(row.Status)">@row.Status</span></td><td><a asp-action="Details" asp-route-id="@row.Id" class="btn btn-outline btn-sm">Review</a></td></tr>}</tbody></table></div>}</div>
