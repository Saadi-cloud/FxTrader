@model SystemSettingsModel
@{ ViewData["Title"]="System Settings"; ViewData["Subtitle"]="Configure withdrawal limits, investment-wallet fee, and support links"; }
<form method="post"><div asp-validation-summary="ModelOnly"></div><div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Default Withdrawal Controls</h3></div><div class="field-group"><label class="field-label" asp-for="DefaultWithdrawalMin">Minimum withdrawal</label><input class="field-input" asp-for="DefaultWithdrawalMin"><span asp-validation-for="DefaultWithdrawalMin"></span></div><div class="field-group"><label class="field-label" asp-for="DefaultWithdrawalMax">Maximum withdrawal</label><input class="field-input" asp-for="DefaultWithdrawalMax"><span asp-validation-for="DefaultWithdrawalMax"></span></div><div class="field-group"><label class="field-label" asp-for="DefaultWithdrawalFeePercent">Investment withdrawal fee percentage</label><input class="field-input" asp-for="DefaultWithdrawalFeePercent"><span asp-validation-for="DefaultWithdrawalFeePercent"></span></div><div class="alert-box alert-info"><span>This fee applies only when a user selects the Investment Wallet. Profit + Commission withdrawals have 0% fee. User-specific fee overrides take priority. Payment-method minimum and maximum limits are still checked.</span></div></div><div class="card card-pad"><div class="card-head"><h3>Support Information</h3></div><div class="field-group"><label class="field-label" asp-for="SupportEmail">Support email</label><input class="field-input" asp-for="SupportEmail"></div><div class="field-group"><label class="field-label" asp-for="TelegramUrl">Telegram URL</label><input class="field-input" asp-for="TelegramUrl"></div></div></div><div class="admin-actions" style="margin-top:18px;"><button class="btn btn-gold" type="submit">Save Settings</button></div></form>
