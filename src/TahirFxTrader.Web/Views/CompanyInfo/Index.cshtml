    <!-- About -->
    <section class="ci-about mt-5">
        <div class="ci-about-copy">
            <h1 class="ci-heading">About OLX Trade</h1>
            <p>
                OLX Trade is an investment company focused on creating opportunities through professionally
                managed gold and silver trading. Investors provide capital, our team uses that capital in
                planned precious-metals trading activities, and eligible profits are distributed according
                to the agreed investment terms and actual performance. Investment returns are not guaranteed,
                and all investments involve risk.
            </p>
        </div>
        <div class="ci-about-logo" aria-hidden="true">
            <div class="ci-logo-ring">
                <div class="ci-logo-inner">
                    <img src="~/images/brand/logo.png" alt="" class="ci-logo-img">
                </div>
            </div>
        </div>
    </section>

    <hr class="ci-divider" />

