        align-items: center;
        gap: 8px;
    }

    .balance-eye-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        padding: 0;
        border: none;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 8px;
        color: #848e9c;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
    }

        .balance-eye-btn:hover {
            background: rgba(240, 185, 11, 0.1);
            color: var(--gold, #f0b90b);
        }

        .balance-eye-btn svg {
            width: 17px;
            height: 17px;
        }

    .trade-social-grid .sp.youtube span {
        background: transparent;
    }

        .trade-social-grid .sp.youtube span svg {
            width: 26px;
            height: 26px;
            display: block;
        }

    .trade-social-grid .sp.youtube:hover {
        border-color: #ff0000;
        transform: translateY(-3px);
    }

        .trade-social-grid .sp.youtube:hover span svg rect {
            fill: #e60000;
        }

    .trade-social-grid .sp.youtube span svg {
        width: 26px;
        height: 26px;
        display: block;
        animation: yt-pulse 2.4s ease-in-out infinite;
    }

    @@keyframes yt-pulse {
        0%, 100%

    {
        transform: scale(1);
        filter: drop-shadow(0 0 0 rgba(255, 0, 0, 0));
    }

    50% {
        transform: scale(1.08);
        filter: drop-shadow(0 0 6px rgba(255, 0, 0, 0.55));
    }

    }

    .trade-social-grid .sp.youtube:hover span svg {
        animation: none;
        transform: scale(1.15);
        filter: drop-shadow(0 0 10px rgba(255, 0, 0, 0.7));
        transition: transform 0.2s ease, filter 0.2s ease;
    }

    .trade-social-grid .sp.youtube:hover {
        border-color: #ff0000;
        transform: translateY(-3px);
    }

    @@media (prefers-reduced-motion: reduce) {
        .trade-social-grid .sp.youtube span svg

    {
        animation: none;
    }

    }
</style>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var display = document.getElementById('balanceDisplay');
            var toggleBtn = document.getElementById('balanceToggle');
            var eyeOpen = document.getElementById('eyeOpen');
            var eyeClosed = document.getElementById('eyeClosed');
            if (!display || !toggleBtn) {
                console.warn('Balance toggle elements not found');
                return;
            }

            var realValue = '$' + display.dataset.realValue;
            var maskedValue = '*****';
            var isHidden = localStorage.getItem('olx_balance_hidden') === 'true';

            function render() {
                display.textContent = isHidden ? maskedValue : realValue;
                eyeOpen.style.display = isHidden ? 'none' : '';
                eyeClosed.style.display = isHidden ? '' : 'none';
            }

            toggleBtn.addEventListener('click', function () {
                isHidden = !isHidden;
                localStorage.setItem('olx_balance_hidden', isHidden);
                render();
            });

            render();
        });
    </script>
}

