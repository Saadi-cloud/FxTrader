@model ChangePasswordRequest
@{ ViewData["Title"]="Account Security"; ViewData["Subtitle"]="Change your password and protect your account"; }
<div class="dash-grid"><div class="card card-pad"><div class="card-head"><h3>Account</h3></div><div class="detail-grid"><div class="detail-item"><span>Name</span><strong>@User.Identity?.Name</strong></div><div class="detail-item"><span>Email</span><strong>@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</strong></div><div class="detail-item"><span>Role</span><strong>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</strong></div><div class="detail-item"><span>Authentication</span><strong>Email verified</strong></div></div><div class="alert-box alert-info"><span>Use a unique password with at least eight characters. Do not reuse a password from another website.</span></div></div><div class="card card-pad"><div class="card-head"><h3>Change Password</h3></div><form method="post"><div asp-validation-summary="ModelOnly"></div><div class="field-group"><label class="field-label" asp-for="CurrentPassword"></label><input class="field-input" asp-for="CurrentPassword"><span asp-validation-for="CurrentPassword"></span></div><div class="field-group"><label class="field-label" asp-for="NewPassword"></label><input class="field-input" asp-for="NewPassword"><span asp-validation-for="NewPassword"></span></div><div class="field-group"><label class="field-label" asp-for="ConfirmPassword"></label><input class="field-input" asp-for="ConfirmPassword"><span asp-validation-for="ConfirmPassword"></span></div><button class="btn btn-gold btn-block" type="submit">Change Password</button></form></div></div>
