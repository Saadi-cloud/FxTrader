@model VerifyEmailRequest
@{ Layout = "_AuthLayout"; ViewData["Title"] = "Verify email"; }
<h2 style="font-size:23px;font-weight:700;margin:0 0 6px;">Verify your email</h2><p style="color:var(--text-muted);font-size:14px;margin:0 0 24px;">Enter the six-digit code sent to <strong>@Model.Email</strong>.</p>
<form method="post"><div asp-validation-summary="ModelOnly"></div><input asp-for="Email" type="hidden"><div class="field-group"><label class="field-label" asp-for="Code">Verification code</label><input class="field-input mono" asp-for="Code" inputmode="numeric" maxlength="6" placeholder="000000"><span asp-validation-for="Code"></span></div><button class="btn btn-gold btn-block" type="submit">Verify email</button></form>
<form asp-action="ResendVerification" method="post" style="margin-top:12px;"><input type="hidden" name="email" value="@Model.Email"><button class="btn btn-outline btn-block" type="submit">Send a new code</button></form>
