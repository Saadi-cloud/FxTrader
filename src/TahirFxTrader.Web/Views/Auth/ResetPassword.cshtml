@model ResetPasswordRequest
@{ Layout = "_AuthLayout"; ViewData["Title"] = "Reset password"; }
<h2 style="font-size:23px;font-weight:700;margin:0 0 6px;">Choose a new password</h2><p style="color:var(--text-muted);font-size:14px;margin:0 0 24px;">Enter the code from your email and a secure password.</p>
<form method="post"><div asp-validation-summary="ModelOnly"></div><input asp-for="Email" type="hidden"><div class="field-group"><label class="field-label" asp-for="Code">Reset code</label><input class="field-input mono" asp-for="Code" maxlength="6"><span asp-validation-for="Code"></span></div><div class="field-group"><label class="field-label" asp-for="NewPassword">New password</label><input class="field-input" asp-for="NewPassword"><span asp-validation-for="NewPassword"></span></div><div class="field-group"><label class="field-label" asp-for="ConfirmPassword">Confirm password</label><input class="field-input" asp-for="ConfirmPassword"><span asp-validation-for="ConfirmPassword"></span></div><button class="btn btn-gold btn-block" type="submit">Update password</button></form>
