@model ForgotPasswordRequest
@{ Layout = "_AuthLayout"; ViewData["Title"] = "Forgot password"; }
<h2 style="font-size:23px;font-weight:700;margin:0 0 6px;">Reset your password</h2><p style="color:var(--text-muted);font-size:14px;margin:0 0 24px;">We will send a six-digit reset code to your email.</p>
<form method="post"><div asp-validation-summary="ModelOnly"></div><div class="field-group"><label class="field-label" asp-for="Email"></label><input class="field-input" asp-for="Email" placeholder="you@example.com"><span asp-validation-for="Email"></span></div><button class="btn btn-gold btn-block" type="submit">Send reset code</button></form><div class="auth-link-row"><a asp-action="Login">Back to login</a></div>
