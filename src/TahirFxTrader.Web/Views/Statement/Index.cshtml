@model IReadOnlyList<LedgerEntry>
@{ ViewData["Title"]="Account Statement"; ViewData["Subtitle"]="Approved deposits, compound profit, referral commission, and completed withdrawals"; var credits=Model.Sum(x=>x.Credit); var debits=Model.Sum(x=>x.Debit); }
<div class="mini-stat-row statement-summary-stats"><div class="mini-stat"><div class="mini-stat-label">Total Credits</div><div class="mini-stat-value mono" style="color:var(--green);">$@credits.ToString("N2")</div></div><div class="mini-stat"><div class="mini-stat-label">Total Debits</div><div class="mini-stat-value mono">$@debits.ToString("N2")</div></div><div class="mini-stat"><div class="mini-stat-label">Current Balance</div><div class="mini-stat-value mono">$@(Model.FirstOrDefault()?.BalanceAfter.ToString("N2") ?? "0.00")</div></div></div>
<div class="card card-pad">
    <h3>Wallet Ledger</h3>
    <div class="card-head">
   
    <div class="tabs-row"><button class="tab-btn active" data-target="all">All</button><button class="tab-btn" data-target="deposit">Deposits</button><button class="tab-btn" data-target="profit">Profit</button><button class="tab-btn" data-target="commission">Commission</button><button class="tab-btn" data-target="withdrawal">Withdrawals</button></div></div>
    @if(Model.Count==0){<div class="empty-state">No ledger entries found.</div>}else{<div class="table-wrap"><table class="data-table"><thead><tr><th>Date</th><th>Reference</th><th>Description</th><th>Credit</th><th>Debit</th><th>Investment</th><th>Profit</th><th>Commission</th><th>Running Balance</th></tr></thead><tbody>@foreach(var row in Model){var type=row.EntryType.Contains("Deposit",StringComparison.OrdinalIgnoreCase)?"deposit":row.EntryType.Contains("Referral",StringComparison.OrdinalIgnoreCase)||row.EntryType.Contains("Commission",StringComparison.OrdinalIgnoreCase)?"commission":row.EntryType.Contains("Profit",StringComparison.OrdinalIgnoreCase)||row.EntryType.Contains("Bonus",StringComparison.OrdinalIgnoreCase)?"profit":"withdrawal";<tr data-row-type="@type"><td>@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td><td class="mono">@row.ReferenceNo</td><td>@row.Description</td><td class="mono" style="color:var(--green);">@(row.Credit>0?"+$"+row.Credit.ToString("N2"):"—")</td><td class="mono" style="color:var(--red);">@(row.Debit>0?"-$"+row.Debit.ToString("N2"):"—")</td><td class="mono">$@row.InvestmentBalanceAfter.ToString("N2")</td><td class="mono" style="color:var(--green);">$@row.ProfitBalanceAfter.ToString("N2")</td><td class="mono" style="color:var(--gold);">$@row.CommissionBalanceAfter.ToString("N2")</td><td class="mono">$@row.BalanceAfter.ToString("N2")</td></tr>}</tbody></table></div>}</div>
