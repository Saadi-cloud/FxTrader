@{
    var title = ViewData["Title"]?.ToString() ?? "Account";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Login";
    var isRegister = action.Equals("Register", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="dark">
    <title>@title — OLX Trade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
</head>
<body class="olx-auth-body">
    <div class="olx-auth-shell @(isRegister ? "olx-auth-shell-register" : "olx-auth-shell-center")">
        @if (isRegister)
        {
            <section class="olx-auth-hero" aria-label="OLX Trade introduction">
                <div class="olx-auth-hero-inner">
                    <h1>Join me on OLX Trade</h1>
                    <div class="olx-orbit-art" aria-hidden="true">
                        <span class="olx-orbit olx-orbit-one"></span>
                        <span class="olx-orbit olx-orbit-two"></span>
                        <span class="olx-orbit-arrow olx-orbit-arrow-one"></span>
                        <span class="olx-orbit-arrow olx-orbit-arrow-two"></span>
                        <span class="olx-hero-emblem"><span>OT</span></span>
                    </div>
                    <div class="olx-trust-list">
                        <div class="olx-trust-item">
                            <span class="olx-trust-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 21h8M12 17v4M5 3h14v5a7 7 0 0 1-14 0V3Z"/><path d="M5 6H2v2a4 4 0 0 0 4 4M19 6h3v2a4 4 0 0 1-4 4"/></svg>
                            </span>
                            <span><strong>Transparent account records</strong><small>Track investment, profit, referrals and withdrawals.</small></span>
                        </div>
                        <div class="olx-trust-item">
                            <span class="olx-trust-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3 4 6v5c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V6l-8-3Z"/><path d="m9 12 2 2 4-5"/></svg>
                            </span>
                            <span><strong>Unique user trace identity</strong><small>Every member receives a permanent USR reference.</small></span>
                        </div>
                        <div class="olx-trust-item">
                            <span class="olx-trust-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="8" cy="8" r="3"/><circle cx="17" cy="7" r="2.5"/><path d="M2 21c0-4 2.7-7 6-7s6 3 6 7M14 14c3 0 5 2.5 5 6"/></svg>
                            </span>
                            <span><strong>Referral rewards</strong><small>Rewards qualify after the referred user’s first approved deposit.</small></span>
                        </div>
                    </div>
                </div>
            </section>
        }

        <main class="olx-auth-main">
            <div class="olx-auth-card @(isRegister ? "olx-auth-card-register" : string.Empty)">
                <a asp-controller="Auth" asp-action="Login" class="olx-auth-wordmark" aria-label="OLX Trade home">
                    <img class="brand-logo" src="/images/brand/logo.png" alt="OLX Trade">
                    @* <span class="olx-auth-brand-text">OLX TRADE</span> *@
                </a>
                <partial name="_Flash" />
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
