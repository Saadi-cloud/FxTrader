@model IReadOnlyList<DepositTransaction>
@{ ViewData["Title"] = "Deposit History"; ViewData["Subtitle"] = "Track every submitted and approved deposit"; string Badge(TransactionStatus s)=>s==TransactionStatus.Approved?"badge-success":s==TransactionStatus.Rejected?"badge-danger":"badge-pending"; }
<div class="mini-stat-row deposit-summary-stats">
   @*  <div class="mini-stat">
        <div class="mini-stat-label">Total Requests</div>
        <div class="mini-stat-value">@Model.Count</div>
    </div> *@
    <div class="mini-stat ">
        <div class="mini-stat-label">Approved</div>
        <div class="mini-stat-value mono" style="color:var(--green);">$@Model.Where(x => x.Status == TransactionStatus.Approved).Sum(x => x.NetAmount).ToString("N2")</div>
    </div>
    <div class="mini-stat">
        <div class="mini-stat-label">Pending</div>
        <div class="mini-stat-value">@Model.Count(x => x.Status == TransactionStatus.Pending)</div>
    </div>
</div>
<div class="card card-pad">
    <div class="card-head">
        <h3>Deposit Requests</h3>
        <a asp-action="Create" class="btn btn-gold btn-sm">New Deposit</a>
    </div>@if(Model.Count==0){
    <div class="empty-state">No deposit requests found.</div>
        }else
    {

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Reference</th>
                        <th>Method</th>
                        <th>Transaction ID</th>
                        <th>Amount</th>
                        <th>Net Credit</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td>@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            <td class="mono">@row.ReferenceNo</td>
                            <td>@row.PaymentMethodName</td>
                            <td class="mono">@row.TransactionReference</td>
                            <td class="mono">$@row.Amount.ToString("N2")</td>
                            <td class="mono">$@row.NetAmount.ToString("N2")</td>
                            <td>
                                <span class="badge @Badge(row.Status)">@row.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>